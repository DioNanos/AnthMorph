#!/bin/sh
set -eu

SCRIPT_PATH=$(readlink -f -- "$0" 2>/dev/null || printf "%s" "$0")
ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")/.." && pwd)
RELEASE_BIN=$ROOT_DIR/target/release/anthmorph
DEBUG_BIN=$ROOT_DIR/target/debug/anthmorph
IS_TERMUX=0

if [ -n "${TERMUX_VERSION:-}" ] || [ "${PREFIX:-}" = "/data/data/com.termux/files/usr" ]; then
  IS_TERMUX=1
fi

case "$(uname -s 2>/dev/null || printf unknown):$(uname -m 2>/dev/null || printf unknown):$IS_TERMUX" in
  Linux:x86_64:*) PREBUILT_BIN=$ROOT_DIR/prebuilt/linux-x64/anthmorph ;;
  Linux:aarch64:1|Linux:arm64:1) PREBUILT_BIN=$ROOT_DIR/prebuilt/android-arm64/anthmorph ;;
  *) PREBUILT_BIN= ;;
esac

if [ -n "$PREBUILT_BIN" ] && [ -x "$PREBUILT_BIN" ]; then
  exec "$PREBUILT_BIN" "$@"
fi

if [ -x "$RELEASE_BIN" ]; then
  exec "$RELEASE_BIN" "$@"
fi

if [ -x "$DEBUG_BIN" ]; then
  exec "$DEBUG_BIN" "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  (cd "$ROOT_DIR" && cargo build --release --quiet)
  exec "$RELEASE_BIN" "$@"
fi

echo "anthmorph binary not found and cargo is unavailable" >&2
exit 1
