#!/bin/sh
set -eu

STATE_DIR=${HOME}/.config/anthmorph
VAULT_DIR=$STATE_DIR/vault
KEYCHAIN_SERVICE=AnthMorph

usage() {
  cat <<'EOF'
usage:
  anthmorph-secret get REF
  anthmorph-secret set REF VALUE
  anthmorph-secret delete REF

refs:
  keychain:NAME
  vault:NAME
EOF
}

backend_from_ref() {
  case "$1" in
    keychain:*) printf 'keychain' ;;
    vault:*) printf 'vault' ;;
    *)
      echo "unsupported secret ref: $1" >&2
      exit 1
      ;;
  esac
}

name_from_ref() {
  printf '%s' "${1#*:}"
}

ensure_vault_passphrase() {
  if [ -n "${ANTHMORPH_VAULT_PASSPHRASE:-}" ]; then
    return 0
  fi
  if [ -t 0 ]; then
    printf 'Vault passphrase: ' >&2
    stty -echo
    IFS= read -r ANTHMORPH_VAULT_PASSPHRASE
    stty echo
    printf '\n' >&2
    export ANTHMORPH_VAULT_PASSPHRASE
    return 0
  fi
  echo "ANTHMORPH_VAULT_PASSPHRASE not set" >&2
  exit 1
}

vault_path() {
  mkdir -p "$VAULT_DIR"
  printf '%s/%s.enc' "$VAULT_DIR" "$(name_from_ref "$1")"
}

secret_get() {
  ref=$1
  case "$(backend_from_ref "$ref")" in
    keychain)
      security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$(name_from_ref "$ref")" -w
      ;;
    vault)
      ensure_vault_passphrase
      openssl enc -d -aes-256-cbc -pbkdf2 \
        -in "$(vault_path "$ref")" \
        -pass "pass:${ANTHMORPH_VAULT_PASSPHRASE}"
      ;;
  esac
}

secret_set() {
  ref=$1
  value=$2
  case "$(backend_from_ref "$ref")" in
    keychain)
      security add-generic-password -U -s "$KEYCHAIN_SERVICE" -a "$(name_from_ref "$ref")" -w "$value" >/dev/null
      ;;
    vault)
      ensure_vault_passphrase
      printf '%s' "$value" | openssl enc -aes-256-cbc -pbkdf2 \
        -out "$(vault_path "$ref")" \
        -pass "pass:${ANTHMORPH_VAULT_PASSPHRASE}"
      ;;
  esac
}

secret_delete() {
  ref=$1
  case "$(backend_from_ref "$ref")" in
    keychain)
      security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$(name_from_ref "$ref")" >/dev/null 2>&1 || true
      ;;
    vault)
      rm -f "$(vault_path "$ref")"
      ;;
  esac
}

cmd=${1:-}
case "$cmd" in
  get)
    [ $# -eq 2 ] || { usage >&2; exit 1; }
    secret_get "$2"
    ;;
  set)
    [ $# -eq 3 ] || { usage >&2; exit 1; }
    secret_set "$2" "$3"
    ;;
  delete)
    [ $# -eq 2 ] || { usage >&2; exit 1; }
    secret_delete "$2"
    ;;
  help|-h|--help|"")
    usage
    ;;
  *)
    echo "unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
